{
  "builds": [
    {
      "use": "@vercel/python",
      "src": "api/index.py"
    },
    {
      "use": "@vercel/static",
      "src": "public/"
    }
  ],
  "routes": [
    {
      "dest": "/api/index.py",
      "src": "/api/(.*)"
    },
    {
      "dest": "/public/index.html",
      "src": "/"
    }
  ]
}
