{
  "builds": [
    {
      "use": "@vercel/python",
      "src": "api/index.py"
    },
    {
      "use": "@vercel/static",
      "src": "public/**"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
